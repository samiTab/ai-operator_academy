# ─────────────────────────────────────────────────────────────────────────────
#  Provider-agnostic LLM config (OpenAI-compatible). DEFAULT: Groq (free tier).
#  Used ONLY by the Vite dev proxy, server-side — never exposed to the browser.
#  Copy this file to ".env" and paste your key.
# ─────────────────────────────────────────────────────────────────────────────

# Default provider: Groq Cloud free tier. Get a free key at https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Model IDs per task (client-visible — they're just names). Override as you like.
#   gpt-oss-120b → strict-JSON capable, best quality for personalizer/grader
#   llama-3.3-70b-versatile → fast chat for the sandbox
VITE_LLM_MODEL_PERSONALIZER=openai/gpt-oss-120b
VITE_LLM_MODEL_GRADER=openai/gpt-oss-120b
VITE_LLM_MODEL_SANDBOX=llama-3.3-70b-versatile

# ── Switching providers ──────────────────────────────────────────────────────
# Change LLM_BASE_URL + LLM_API_KEY to any OpenAI-compatible endpoint and set the
# model IDs accordingly. Examples:
#   Google Gemini : LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#                   models e.g. gemini-2.5-flash  (NOTE: free tier trains on your data —
#                   enable billing before sending real learner data)
#   OpenRouter    : LLM_BASE_URL=https://openrouter.ai/api/v1   (lets you use Claude/others)
#   Cerebras      : LLM_BASE_URL=https://api.cerebras.ai/v1
#
# Free tiers are for dev/MVP only — expect rate limits (429s). The app already retries
# with backoff. Enable billing on your provider before a real launch.
